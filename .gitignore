# ---- Large model artifacts (regenerated by the training scripts) ----
# DistilBERT safetensors are ~255MB each and exceed GitHub's 100MB limit.
# Recreate with:  python src/train_text_models.py --distilbert --epochs 12
models/issue_classifier_distilbert/
models/churn_signal_classifier_distilbert/
models/**/model.safetensors
models/**/_hf_trainer/
# Hugging Face / torch caches (never commit these)
.cache/
hf_cache/

# NOTE: the small sklearn models (*.joblib) ARE committed so a fresh clone runs
# immediately with the TF-IDF + churn models. Only the heavy transformers are ignored.

# ---- Runtime artifacts ----
outputs/audit_log.csv          # per-user runtime log; starts empty
scratchpad/
*.log

# ---- Streamlit secrets (never commit) ----
.streamlit/secrets.toml
